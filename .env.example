# Dashboard Configuration
DASHBOARD_BASE_URL=https://ailifeassistanttm.com
TZ=America/Denver

# Machine Authentication (set in production; empty in development)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
DASHBOARD_HMAC_SECRET=

# Server Configuration
NODE_ENV=production
PORT=8080
TRUST_PROXY=1

# Events & Live Updates
EVENTS_ENABLED=true
EVENTS_KEEPALIVE_MS=15000

# Security Configuration
CSP_ENABLED=true
HSTS_MAXAGE=31536000
BODY_LIMIT_BYTES=524288

# Optional Data Sources for n8n Flows (defaults can be empty)
SUPPLEMENTS_SOURCE=sheet
SUPPLEMENTS_SHEET_ID=
SUPPLEMENTS_SHEET_RANGE=Supplements!A:F
WORKOUT_SOURCE=trainer
WORKOUT_SHEET_ID=
WORKOUT_SHEET_RANGE=Today!A:E
TRAINER_API_URL=
TRAINER_API_KEY=

# Legacy Configuration (maintained for compatibility)
VITE_API_BASE_URL=http://localhost:3000/api

# AI Provider Configuration
PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Communication Providers
EMAIL_PROVIDER=sendgrid
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_API_KEY=your_sendgrid_api_key
RESEND_API_KEY=your_resend_api_key

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Optional Services
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
N8N_BASE_URL=your_n8n_base_url
N8N_API_KEY=your_n8n_api_key
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key
GOOGLE_SHEETS_ID=your_spreadsheet_id
ENABLE_REALTIME=false