# Frontend environment variables (public, non-sensitive)
VITE_API_BASE_URL=http://localhost:3000/api

# Serverless function environment variables (add to your deployment platform)
# These should NEVER be committed to version control

# AI Provider Configuration
PROVIDER=openai # or anthropic - default AI provider
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o # gpt-5, gpt-4.1, gpt-4o, gpt-4-turbo
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022 # or latest sonnet model

# Email Provider
EMAIL_PROVIDER=sendgrid # or resend
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_API_KEY=your_sendgrid_api_key
RESEND_API_KEY=your_resend_api_key

# SMS/WhatsApp Provider (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# RAG/Knowledge Base Configuration
RAG_STORE=pgvector # or pinecone, lancedb
POSTGRES_URL=your_postgres_url # for pgvector
PINECONE_API_KEY=your_pinecone_api_key # for pinecone
PINECONE_ENV=your_pinecone_env # for pinecone

# Optional: Database (for fitness/nutrition data)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: n8n Webhook URLs
N8N_BASE_URL=your_n8n_base_url
N8N_API_KEY=your_n8n_api_key

# Optional: Google Sheets API
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key
GOOGLE_SHEETS_ID=your_spreadsheet_id

# Optional: Voice/Realtime Configuration
ENABLE_REALTIME=false # Enable OpenAI Realtime voice